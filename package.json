{
  "name": "log-monitor-automation",
  "version": "1.0.0",
  "type": "module",
  "description": "Automated log-to-fix pipeline: scans production logs, classifies errors, creates Jira tickets, generates code fixes via Claude, and monitors CI",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "pipeline": "tsx src/pipeline/runner.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "vitest run tests/unit/classifier.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["automation", "log-monitoring", "error-detection", "claude", "jira", "github"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "nock": "^14.0.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
